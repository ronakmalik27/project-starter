# EditorConfig - https://editorconfig.org
# Baseline for a polyglot repo. Tighten per language in the consuming project.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{cs,csx}]
indent_size = 4

[*.{md,markdown}]
# Trailing whitespace is significant in Markdown (hard line break).
trim_trailing_whitespace = false

[*.{yml,yaml,json,jsonc}]
indent_size = 2

[Makefile]
indent_style = tab

[*.{py}]
indent_size = 4
